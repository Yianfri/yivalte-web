---
import BaseLayout from "../layouts/BaseLayout.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";

const pageTitle = "Cómo pedir - Yivalte";

const steps = [
  {
    title: "Elige tu prenda o producto",
    description:
      "Cuéntanos qué quieres personalizar para entender el tipo de superficie y el uso esperado.",
  },
  {
    title: "Define la ubicación",
    description:
      "Indica si el estampado irá en pecho, espalda, manga u otra zona de la prenda.",
  },
  {
    title: "Envía tu diseño o idea",
    description:
      "Puedes compartir un archivo, una referencia visual o una descripción inicial del resultado que buscas.",
  },
  {
    title: "Revisamos el archivo",
    description:
      "Verificamos de forma preliminar si el diseño sirve para impresión DTF o si necesita ajustes.",
  },
  {
    title: "Confirmamos los detalles",
    description:
      "Te indicamos una referencia de precio, tiempo de entrega y forma de pago cuando la información esté completa.",
  },
  {
    title: "Coordinamos entrega",
    description:
      "Definimos el retiro o envío del pedido según disponibilidad y datos confirmados.",
  },
];
---

<BaseLayout title={pageTitle}>
  <main class="mx-auto max-w-5xl px-6 py-12">
    <section class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-wide text-neutral-500">
        Proceso de cotización
      </p>
      <h1 class="text-3xl font-semibold tracking-normal text-neutral-950">
        Cómo pedir
      </h1>
      <p class="max-w-2xl text-base leading-7 text-neutral-700">
        Contenido placeholder para explicar de forma simple cómo solicitar la
        cotización de un estampado personalizado DTF.
      </p>
    </section>

    <section class="mt-10" aria-labelledby="pasos-para-pedir">
      <div class="mb-6 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <h2
            id="pasos-para-pedir"
            class="text-xl font-semibold text-neutral-950"
          >
            Pasos principales
          </h2>
          <p class="mt-2 max-w-2xl text-sm leading-6 text-neutral-700">
            Este flujo es referencial y podrá ajustarse cuando el contenido
            definitivo esté listo.
          </p>
        </div>
      </div>

      <ol class="grid gap-4 md:grid-cols-2">
        {
          steps.map((step, index) => (
            <li class="rounded-lg border border-neutral-200 bg-white p-5">
              <div class="flex gap-4">
                <span
                  class="grid h-9 w-9 shrink-0 place-items-center rounded-md bg-neutral-950 text-sm font-semibold text-white"
                  aria-hidden="true"
                >
                  {index + 1}
                </span>
                <div class="space-y-2">
                  <h3 class="text-base font-semibold text-neutral-950">
                    {step.title}
                  </h3>
                  <p class="text-sm leading-6 text-neutral-700">
                    {step.description}
                  </p>
                </div>
              </div>
            </li>
          ))
        }
      </ol>
    </section>

    <section
      class="mt-10 grid gap-4 rounded-lg border border-neutral-200 bg-neutral-50 p-6 md:grid-cols-[1fr_auto] md:items-center"
      aria-labelledby="prepara-tu-solicitud"
    >
      <div class="space-y-2">
        <h2
          id="prepara-tu-solicitud"
          class="text-lg font-semibold text-neutral-950"
        >
          Antes de enviar tu solicitud
        </h2>
        <p class="max-w-2xl text-sm leading-6 text-neutral-700">
          Ten a mano el diseño, una referencia del tamaño aproximado y la zona
          donde quieres aplicar el estampado. Esta información ayuda a preparar
          una cotización más clara.
        </p>
      </div>
      <WhatsAppButton />
    </section>
  </main>
</BaseLayout>
