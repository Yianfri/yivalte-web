---
import SectionHeading from "../SectionHeading.astro";

const productOptions = [
  {
    title: "Polera manga corta",
    description:
      "Opción versátil para logos, frases, ilustraciones y diseños frontales o de espalda.",
    detail: "Pecho, espalda o zona pequeña",
    visual: "short",
    accent: "bg-cyan-300",
  },
  {
    title: "Polera manga larga",
    description:
      "Pensada para composiciones con detalle en pecho, espalda o mangas según el archivo.",
    detail: "Frente, espalda o manga",
    visual: "long",
    accent: "bg-neutral-950",
  },
  {
    title: "Polerón",
    description:
      "Buen soporte para piezas protagonistas, marcas de equipo o diseños de mayor presencia.",
    detail: "Pecho, espalda o bolsillo",
    visual: "hoodie",
    accent: "bg-rose-300",
  },
  {
    title: "Polera niños",
    description:
      "Formato infantil para diseños personalizados, nombres o motivos de tamaño controlado.",
    detail: "Tallas infantiles por confirmar",
    visual: "kids",
    accent: "bg-yellow-200",
  },
  {
    title: "Tote bag",
    description:
      "Alternativa textil para bolsas reutilizables, regalos, eventos o identidad de marca.",
    detail: "Una o dos caras según factibilidad",
    visual: "tote",
    accent: "bg-cyan-300",
  },
  {
    title: "Otros textiles",
    description:
      "Placeholder para nuevas bases textiles que se puedan revisar caso a caso antes de cotizar.",
    detail: "Sujeto a material y superficie",
    visual: "stack",
    accent: "bg-neutral-300",
  },
];

const assurances = [
  "Sin precios publicados todavía",
  "Cotización según archivo y cantidad",
  "Mockups referenciales, no trabajos realizados",
];
---

<section
  id="catalogo"
  class="border-t border-neutral-200 bg-white"
  aria-labelledby="catalogo-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[0.82fr_1fr] lg:items-end">
      <SectionHeading
        eyebrow="Catálogo visual"
        title="Opciones principales para empezar una cotización."
        titleId="catalogo-title"
        intro="Estas tarjetas funcionan como guía de productos y soportes posibles. Cada pedido se confirma con revisión de archivo, prenda, ubicación y cantidad."
      />

      <ul class="grid gap-3 sm:grid-cols-3">
        {
          assurances.map((assurance) => (
            <li class="rounded-lg border border-neutral-200 bg-neutral-50 p-4 text-sm font-medium leading-6 text-neutral-700">
              {assurance}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        productOptions.map((product) => (
          <article class="group overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-sm shadow-neutral-950/5 transition duration-200 hover:-translate-y-1 hover:border-neutral-300 hover:shadow-xl hover:shadow-neutral-950/10">
            <div class="relative min-h-64 overflow-hidden bg-neutral-50 p-5">
              <div class="flex items-center justify-between gap-3">
                <span class="rounded-full border border-neutral-200 bg-white px-3 py-1 text-xs font-semibold text-neutral-600">
                  Mockup referencial
                </span>
                <span class={`h-3 w-10 rounded-full ${product.accent}`} aria-hidden="true"></span>
              </div>

              <div class="relative mx-auto mt-8 h-40 max-w-[13rem]" aria-hidden="true">
                {
                  product.visual === "short" && (
                    <>
                      <span class="absolute left-0 top-9 h-14 w-12 -rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute right-0 top-9 h-14 w-12 rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute left-1/2 top-2 z-10 h-32 w-28 -translate-x-1/2 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-1/2 top-2 z-20 h-7 w-12 -translate-x-1/2 rounded-b-full border-b border-neutral-300 bg-neutral-50"></span>
                      <span class="absolute left-1/2 top-16 z-20 h-10 w-10 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                    </>
                  )
                }

                {
                  product.visual === "long" && (
                    <>
                      <span class="absolute left-2 top-8 h-28 w-10 -rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute right-2 top-8 h-28 w-10 rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute left-1/2 top-1 z-10 h-[8.5rem] w-28 -translate-x-1/2 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-1/2 top-1 z-20 h-7 w-12 -translate-x-1/2 rounded-b-full border-b border-neutral-300 bg-neutral-50"></span>
                      <span class="absolute left-1/2 top-[3.75rem] z-20 h-10 w-10 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                    </>
                  )
                }

                {
                  product.visual === "hoodie" && (
                    <>
                      <span class="absolute left-1/2 top-0 h-16 w-24 -translate-x-1/2 rounded-t-full border border-neutral-300 bg-neutral-100"></span>
                      <span class="absolute left-3 top-11 h-[5.5rem] w-10 -rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute right-3 top-11 h-[5.5rem] w-10 rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute left-1/2 top-6 z-10 h-32 w-32 -translate-x-1/2 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute bottom-7 left-1/2 z-20 h-8 w-16 -translate-x-1/2 rounded-md border border-neutral-300 bg-neutral-50"></span>
                      <span class="absolute left-1/2 top-16 z-20 h-9 w-12 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                    </>
                  )
                }

                {
                  product.visual === "kids" && (
                    <>
                      <span class="absolute left-7 top-11 h-11 w-10 -rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute right-7 top-11 h-11 w-10 rotate-12 rounded-md border border-neutral-300 bg-white"></span>
                      <span class="absolute left-1/2 top-5 z-10 h-[6.5rem] w-24 -translate-x-1/2 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-1/2 top-5 z-20 h-6 w-10 -translate-x-1/2 rounded-b-full border-b border-neutral-300 bg-neutral-50"></span>
                      <span class="absolute left-1/2 top-16 z-20 h-8 w-8 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                    </>
                  )
                }

                {
                  product.visual === "tote" && (
                    <>
                      <span class="absolute left-1/2 top-1 h-[4.5rem] w-24 -translate-x-1/2 rounded-t-full border-4 border-b-0 border-neutral-300"></span>
                      <span class="absolute left-1/2 top-12 h-[7.5rem] w-32 -translate-x-1/2 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-1/2 top-[5.5rem] z-20 h-10 w-12 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                      <span class="absolute bottom-3 left-1/2 z-20 h-2 w-20 -translate-x-1/2 rounded-full bg-cyan-300"></span>
                    </>
                  )
                }

                {
                  product.visual === "stack" && (
                    <>
                      <span class="absolute left-8 top-9 h-[5.5rem] w-32 -rotate-6 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-10 top-[3.25rem] h-[5.5rem] w-32 rotate-3 rounded-lg border border-neutral-300 bg-neutral-100 shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-12 top-[4.25rem] h-[5.5rem] w-32 rounded-lg border border-neutral-300 bg-white shadow-lg shadow-neutral-950/10"></span>
                      <span class="absolute left-1/2 top-24 z-20 h-10 w-12 -translate-x-1/2 rounded-md bg-neutral-950"></span>
                    </>
                  )
                }
              </div>
            </div>

            <div class="p-5">
              <h3 class="text-lg font-semibold text-neutral-950">
                {product.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-neutral-700">
                {product.description}
              </p>
              <p class="mt-5 border-t border-neutral-200 pt-4 text-sm font-medium text-neutral-950">
                {product.detail}
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
