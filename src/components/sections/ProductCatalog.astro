---
import { Package, Shirt, ShoppingBag } from "@lucide/astro";
import SectionHeading from "../SectionHeading.astro";

const productOptions = [
  {
    title: "Polera manga corta",
    detail: "Pecho, espalda o zona pequeña",
    visual: "light",
    accent: "bg-cyan-300",
    icon: Shirt,
  },
  {
    title: "Polera manga larga",
    detail: "Frente, espalda o manga",
    visual: "dark",
    accent: "bg-neutral-950",
    icon: Shirt,
  },
  {
    title: "Polerón",
    detail: "Pecho, espalda o bolsillo",
    visual: "dark",
    accent: "bg-rose-300",
    icon: Shirt,
  },
  {
    title: "Polera niños",
    detail: "Tallas infantiles por confirmar",
    visual: "light",
    accent: "bg-yellow-200",
    icon: Shirt,
  },
  {
    title: "Tote bag",
    detail: "Una o dos caras según factibilidad",
    visual: "paper",
    accent: "bg-cyan-300",
    icon: ShoppingBag,
  },
  {
    title: "Otros textiles",
    detail: "Sujeto a material y superficie",
    visual: "paper",
    accent: "bg-neutral-300",
    icon: Package,
  },
];
---

<section
  id="catalogo"
  class="border-t border-neutral-200 bg-yivalte-paper"
  aria-labelledby="catalogo-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1fr] lg:items-end">
      <SectionHeading
        eyebrow="Opciones"
        title="Elige una base para empezar la cotización."
        titleId="catalogo-title"
        intro="Estas categorías ordenan el pedido inicial. Cada estampado se confirma después de revisar archivo, prenda, ubicación y cantidad."
      />

      <div class="grid gap-3 sm:grid-cols-3">
        <p class="rounded-lg border border-neutral-200 bg-white p-4 text-sm leading-6 text-neutral-700">
          Sin precios publicados por ahora.
        </p>
        <p class="rounded-lg border border-neutral-200 bg-white p-4 text-sm leading-6 text-neutral-700">
          Cotización según archivo y cantidad.
        </p>
        <p class="rounded-lg border border-neutral-200 bg-white p-4 text-sm leading-6 text-neutral-700">
          Fotos reales reemplazables cuando estén listas.
        </p>
      </div>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        productOptions.map((product) => {
          const Icon = product.icon;
          const visualClasses = {
            light: "bg-white text-neutral-950",
            dark: "bg-neutral-950 text-white",
            paper: "bg-neutral-100 text-neutral-950",
          }[product.visual];

          return (
            <article class="group overflow-hidden rounded-lg border border-neutral-200 bg-white shadow-sm shadow-neutral-950/5 transition duration-200 hover:-translate-y-1 hover:border-neutral-300 hover:shadow-xl hover:shadow-neutral-950/10">
              <div class={`relative aspect-[4/3] overflow-hidden ${visualClasses}`}>
                <div class="absolute inset-5 rounded-lg border border-current/10"></div>
                <span class={`absolute left-5 top-5 h-2 w-14 rounded-full ${product.accent}`} aria-hidden="true"></span>
                <div class="absolute inset-0 grid place-items-center">
                  <div class="grid h-28 w-28 place-items-center rounded-full border border-current/15 bg-current/[0.04]">
                    <Icon class="size-14" stroke-width={1.4} aria-hidden="true" />
                  </div>
                </div>
                <span class="brand-script absolute bottom-5 right-5 text-3xl opacity-80">
                  Yivalte
                </span>
              </div>

              <div class="p-5">
                <h3 class="text-lg font-semibold text-neutral-950">
                  {product.title}
                </h3>
                <p class="mt-3 border-t border-neutral-200 pt-4 text-sm font-medium text-neutral-700">
                  {product.detail}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
