---
import { ArrowDown, ArrowRight, CheckCircle2 } from "@lucide/astro";

const confidenceItems = [
  "Cotización por prenda, tamaño y cantidad",
  "Revisión previa del diseño",
  "Correo como canal principal",
];
---

<section
  id="inicio"
  class="relative isolate overflow-hidden bg-neutral-950 text-white"
  aria-labelledby="inicio-title"
>
  <div
    class="absolute inset-0 opacity-40 [background-image:linear-gradient(rgba(255,255,255,0.055)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.035)_1px,transparent_1px)] [background-size:44px_44px]"
    aria-hidden="true"
  ></div>
  <div
    class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-white/25 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto grid min-h-[calc(100vh-4.5rem)] max-w-6xl gap-10 px-6 py-16 lg:grid-cols-[0.9fr_1.1fr] lg:items-center lg:py-20">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase text-neutral-400">
        Personaliza tu estilo
      </p>
      <h1
        id="inicio-title"
        class="mt-5 max-w-2xl text-5xl font-semibold leading-[1.02] text-white sm:text-6xl lg:text-7xl"
      >
        Estampados DTF personalizados.
      </h1>
      <p class="mt-6 max-w-xl text-base leading-7 text-neutral-300 sm:text-lg">
        Cotiza poleras, polerones y textiles con impresión DTF según tu diseño,
        ubicación, tamaño y cantidad.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-md bg-white px-5 py-3 text-sm font-semibold text-neutral-950 transition-colors hover:bg-neutral-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-neutral-950"
          href="#cotizar"
        >
          Cotizar estampado
          <ArrowRight class="ml-2 size-4" stroke-width={1.8} aria-hidden="true" />
        </a>
        <a
          class="inline-flex min-h-12 items-center justify-center rounded-md border border-white/25 px-5 py-3 text-sm font-semibold text-white transition-colors hover:border-white hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-neutral-950"
          href="#catalogo"
        >
          Ver opciones
          <ArrowDown class="ml-2 size-4" stroke-width={1.8} aria-hidden="true" />
        </a>
      </div>

      <ul class="mt-9 grid gap-3 text-sm text-neutral-300 sm:grid-cols-3">
        {
          confidenceItems.map((item) => (
            <li class="flex gap-2 rounded-md border border-white/10 bg-white/[0.06] p-3">
              <CheckCircle2 class="mt-0.5 size-4 shrink-0 text-white" stroke-width={1.8} aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="relative min-h-[25rem] lg:min-h-[34rem]" aria-label="Prendas Yivalte referenciales">
      <div
        class="absolute left-[3%] top-[12%] h-[19rem] w-[15rem] -rotate-6 rounded-[1.8rem] border border-white/10 bg-neutral-900 shadow-2xl shadow-black/60 sm:left-[8%] sm:h-[23rem] sm:w-[18rem] lg:h-[26rem] lg:w-[20rem]"
        aria-hidden="true"
      >
        <span class="absolute -left-16 top-16 h-24 w-20 -rotate-12 rounded-[1.2rem] border border-white/10 bg-neutral-900"></span>
        <span class="absolute -right-16 top-16 h-24 w-20 rotate-12 rounded-[1.2rem] border border-white/10 bg-neutral-900"></span>
        <span class="absolute left-1/2 top-0 h-16 w-28 -translate-x-1/2 rounded-b-full border-b border-white/15 bg-neutral-950"></span>
        <span class="brand-script absolute left-1/2 top-[38%] -translate-x-1/2 text-5xl text-white drop-shadow-[0_0_20px_rgba(255,255,255,0.7)]">
          Yivalte
        </span>
        <span class="absolute bottom-8 left-1/2 h-px w-28 -translate-x-1/2 bg-white/25"></span>
      </div>

      <div
        class="absolute right-[1%] top-[2%] h-[23rem] w-[15.5rem] rotate-6 rounded-[2rem] border border-white/10 bg-black shadow-2xl shadow-black/70 sm:right-[7%] sm:h-[27rem] sm:w-[18rem] lg:h-[31rem] lg:w-[20rem]"
        aria-hidden="true"
      >
        <span class="absolute left-1/2 top-0 h-20 w-32 -translate-x-1/2 rounded-t-full border border-white/10 bg-neutral-900"></span>
        <span class="absolute -left-12 top-20 h-36 w-16 -rotate-12 rounded-[1.4rem] border border-white/10 bg-black"></span>
        <span class="absolute -right-12 top-20 h-36 w-16 rotate-12 rounded-[1.4rem] border border-white/10 bg-black"></span>
        <span class="absolute left-1/2 top-[27%] grid h-36 w-36 -translate-x-1/2 place-items-center rounded-full border border-white/35 text-center">
          <span class="text-5xl font-semibold tracking-normal text-white">YV</span>
        </span>
        <span class="absolute bottom-16 left-1/2 h-14 w-28 -translate-x-1/2 rounded-b-2xl border border-white/10 bg-neutral-900"></span>
      </div>

      <div class="absolute bottom-1 left-1/2 w-[82%] -translate-x-1/2 border-t border-white/15 pt-4 text-center text-xs font-semibold uppercase text-neutral-400">
        Yivalte Collection
      </div>
    </div>
  </div>
</section>
