---
import { ArrowDown, CheckCircle2 } from "@lucide/astro";
import WhatsAppButton from "../WhatsAppButton.astro";

const confidenceItems = [
  "DTF personalizado por pedido",
  "Revisión previa del diseño",
  "Poleras, polerones y textiles",
];
---

<section
  id="inicio"
  class="relative isolate overflow-hidden bg-neutral-950 text-white"
  aria-labelledby="inicio-title"
>
  <div
    class="absolute inset-0 opacity-35 [background-image:linear-gradient(rgba(255,255,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] [background-size:52px_52px]"
    aria-hidden="true"
  ></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-white/15" aria-hidden="true"></div>

  <div class="relative mx-auto grid min-h-[calc(100vh-4.5rem)] max-w-6xl gap-10 px-6 py-14 lg:grid-cols-[0.88fr_1.12fr] lg:items-center lg:py-20">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-neutral-400">
        Personaliza tu estilo
      </p>
      <h1
        id="inicio-title"
        class="mt-5 max-w-2xl text-5xl font-semibold leading-[1.02] text-white sm:text-6xl lg:text-7xl"
      >
        Estampados DTF personalizados.
      </h1>
      <p class="mt-6 max-w-xl text-base leading-7 text-neutral-300 sm:text-lg">
        Cotiza prendas y textiles con impresión DTF según tu diseño, ubicación,
        tamaño y cantidad.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <WhatsAppButton tone="inverted" label="Cotizar por WhatsApp" />
        <a
          class="inline-flex min-h-11 items-center justify-center rounded-md border border-white/25 px-5 py-3 text-sm font-semibold text-white transition-colors hover:border-white hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-neutral-950"
          href="#catalogo"
        >
          Ver opciones
          <ArrowDown class="ml-2 size-4" stroke-width={1.8} aria-hidden="true" />
        </a>
      </div>

      <ul class="mt-9 hidden gap-3 text-sm text-neutral-300 sm:grid sm:grid-cols-3">
        {
          confidenceItems.map((item) => (
            <li class="flex min-h-16 gap-2 rounded-md border border-white/10 bg-white/[0.06] p-3">
              <CheckCircle2 class="mt-0.5 size-4 shrink-0 text-white" stroke-width={1.8} aria-hidden="true" />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="relative min-h-[22rem] sm:min-h-[30rem] lg:min-h-[38rem]" aria-label="Polerones Yivalte con estampado referencial">
      <img
        src="/images/yivalte/hero-hoodie-logo.png"
        alt="Polerón negro Yivalte con estampado frontal y trasero"
        class="absolute inset-0 h-full w-full object-contain object-center drop-shadow-[0_30px_80px_rgba(0,0,0,0.75)]"
        loading="eager"
      />
      <div class="absolute bottom-2 left-1/2 w-[82%] -translate-x-1/2 border-t border-white/15 pt-4 text-center text-xs font-semibold uppercase tracking-[0.32em] text-neutral-400">
        Yivalte Collection
      </div>
    </div>
  </div>
</section>
