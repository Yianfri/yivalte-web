<section
  id="inicio"
  class="bg-white"
  aria-labelledby="inicio-title"
>
  <div
    class="mx-auto grid max-w-6xl gap-12 px-6 py-16 lg:grid-cols-[1fr_0.88fr] lg:items-center lg:py-24"
  >
    <div class="space-y-8">
      <div class="space-y-5">
        <p class="text-sm font-semibold uppercase tracking-wide text-neutral-500">
          Estampados personalizados DTF
        </p>
        <h1
          id="inicio-title"
          class="max-w-3xl text-4xl font-semibold tracking-normal text-neutral-950 sm:text-5xl lg:text-6xl"
        >
          Estampados DTF a medida para prendas y textiles.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-neutral-700">
          En Yivalte cotizamos cada pedido según tu diseño, tamaño, ubicación,
          prenda y cantidad. Envía tu idea o archivo y te guiamos para dejarlo
          listo para producción.
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row">
        <a
          class="inline-flex min-h-11 items-center justify-center rounded-md bg-neutral-950 px-5 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-neutral-800 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950 focus-visible:ring-offset-2"
          href="#contacto"
        >
          Cotizar estampado
        </a>
        <a
          class="inline-flex min-h-11 items-center justify-center rounded-md border border-neutral-300 px-5 py-3 text-center text-sm font-semibold text-neutral-900 transition-colors hover:border-neutral-950 hover:bg-neutral-50 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950 focus-visible:ring-offset-2"
          href="#requisitos-diseno"
        >
          Preparar archivo
        </a>
      </div>

      <dl class="grid max-w-2xl gap-3 sm:grid-cols-3">
        <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            Servicio
          </dt>
          <dd class="mt-2 text-sm font-medium text-neutral-950">
            Cotización personalizada
          </dd>
        </div>
        <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            Archivo
          </dt>
          <dd class="mt-2 text-sm font-medium text-neutral-950">
            Revisión previa
          </dd>
        </div>
        <div class="rounded-lg border border-neutral-200 bg-neutral-50 p-4">
          <dt class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
            Canal
          </dt>
          <dd class="mt-2 text-sm font-medium text-neutral-950">
            WhatsApp o Instagram
          </dd>
        </div>
      </dl>
    </div>

    <aside
      class="relative overflow-hidden rounded-lg border border-neutral-200 bg-neutral-950 p-5 text-white shadow-xl shadow-neutral-950/10"
      aria-labelledby="hero-mockup-title"
    >
      <div class="absolute right-6 top-6 flex gap-2" aria-hidden="true">
        <span class="h-3 w-3 rounded-full bg-cyan-300"></span>
        <span class="h-3 w-3 rounded-full bg-rose-300"></span>
        <span class="h-3 w-3 rounded-full bg-yellow-200"></span>
      </div>

      <div class="space-y-5">
        <div>
          <p id="hero-mockup-title" class="text-sm font-semibold text-white">
            Preparación de pedido
          </p>
          <p class="mt-1 text-xs leading-5 text-neutral-300">
            Visual referencial: no muestra trabajos reales.
          </p>
        </div>

        <div class="rounded-md bg-white p-4 text-neutral-950">
          <div class="grid gap-3 sm:grid-cols-[1fr_0.8fr]">
            <div class="min-h-52 rounded-md border border-dashed border-neutral-300 bg-neutral-50 p-4">
              <div class="mb-8 h-3 w-24 rounded bg-neutral-300"></div>
              <div class="mx-auto grid h-28 w-28 place-items-center rounded-md bg-neutral-950 text-3xl font-semibold text-white">
                Y
              </div>
              <div class="mx-auto mt-8 h-3 w-36 rounded bg-neutral-300"></div>
            </div>
            <div class="space-y-3">
              <div class="rounded-md border border-neutral-200 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                  Ubicación
                </p>
                <p class="mt-2 text-sm font-medium">Pecho, espalda o manga</p>
              </div>
              <div class="rounded-md border border-neutral-200 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                  Tamaño
                </p>
                <p class="mt-2 text-sm font-medium">A confirmar con referencia</p>
              </div>
              <div class="rounded-md border border-neutral-200 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-neutral-500">
                  Estado
                </p>
                <p class="mt-2 text-sm font-medium">Listo para revisar</p>
              </div>
            </div>
          </div>
        </div>

        <p class="text-sm leading-6 text-neutral-300">
          Envíanos el diseño, una referencia de ubicación y el tamaño aproximado
          para responder con una cotización más clara.
        </p>
      </div>
    </aside>
  </div>
</section>
