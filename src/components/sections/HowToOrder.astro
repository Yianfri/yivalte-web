---
import { MailCheck, PencilRuler, Ruler, Shirt } from "@lucide/astro";
import SectionHeading from "../SectionHeading.astro";

const steps = [
  {
    title: "Elige tu prenda",
    description: "Polera, polerón, tote bag u otro textil.",
    icon: Shirt,
  },
  {
    title: "Define tamaño",
    description: "Indica ubicación, medida aproximada y cantidad.",
    icon: Ruler,
  },
  {
    title: "Manda tu diseño",
    description: "Sirve un archivo, link, referencia o descripción.",
    icon: PencilRuler,
  },
  {
    title: "Recibe respuesta",
    description: "Revisamos el caso y volvemos con la cotización.",
    icon: MailCheck,
  },
];
---

<section
  id="como-pedir"
  class="border-t border-neutral-200 bg-yivalte-paper"
  aria-labelledby="como-pedir-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[0.72fr_1fr] lg:items-start">
      <SectionHeading
        eyebrow="Cómo pedir"
        title="Un proceso simple para pasar de idea a cotización."
        titleId="como-pedir-title"
        intro="La idea es reunir lo justo: prenda, ubicación, tamaño, cantidad y una referencia del diseño."
      />

      <ol class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, index) => {
            const Icon = step.icon;

            return (
              <li class="relative">
                {index < steps.length - 1 && (
                  <span class="absolute left-[calc(50%+2rem)] top-8 hidden h-px w-[calc(100%-4rem)] border-t border-dashed border-neutral-300 lg:block" aria-hidden="true"></span>
                )}
                <div class="relative grid gap-4 rounded-lg border border-neutral-200 bg-white p-5 shadow-sm shadow-neutral-950/5">
                  <span class="grid h-16 w-16 place-items-center rounded-full border border-neutral-200 bg-neutral-50 text-neutral-950">
                    <Icon class="size-6" stroke-width={1.7} aria-hidden="true" />
                  </span>
                  <span class="absolute right-4 top-4 grid h-6 w-6 place-items-center rounded-full bg-neutral-950 text-xs font-semibold text-white">
                    {index + 1}
                  </span>
                  <h3 class="text-base font-semibold text-neutral-950">
                    {step.title}
                  </h3>
                  <p class="text-sm leading-6 text-neutral-700">
                    {step.description}
                  </p>
                </div>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
