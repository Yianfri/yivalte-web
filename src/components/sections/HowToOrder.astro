---
import { MailCheck, PencilRuler, Ruler, Shirt } from "@lucide/astro";
import SectionHeading from "../SectionHeading.astro";

const steps = [
  {
    title: "Elige tu prenda",
    description: "Polera, polerón, tote bag u otro textil.",
    icon: Shirt,
  },
  {
    title: "Define tamaño",
    description: "Indica ubicación, medida aproximada y cantidad.",
    icon: Ruler,
  },
  {
    title: "Manda tu idea",
    description: "Sirve un archivo, link, referencia o descripción.",
    icon: PencilRuler,
  },
  {
    title: "Recibe respuesta",
    description: "Revisamos el caso y volvemos con la cotización.",
    icon: MailCheck,
  },
];
---

<section
  id="como-pedir"
  class="border-t border-neutral-200 bg-white"
  aria-labelledby="como-pedir-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-24">
    <div class="grid gap-10 lg:grid-cols-[0.72fr_1fr] lg:items-start">
      <SectionHeading
        eyebrow="Cómo pedir"
        title="Cotizar debería sentirse simple."
        titleId="como-pedir-title"
        intro="El formulario ordena la información para que la respuesta llegue con contexto y no parta desde cero."
      />

      <ol class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          steps.map((step, index) => {
            const Icon = step.icon;

            return (
              <li class="relative rounded-lg border border-neutral-200 bg-neutral-50 p-5">
                <span class="absolute right-4 top-4 text-xs font-semibold text-neutral-400">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <span
                  class="grid h-12 w-12 place-items-center rounded-full border border-neutral-200 bg-white text-neutral-950"
                  aria-hidden="true"
                >
                  <Icon class="size-5" stroke-width={1.8} />
                </span>
                <h3 class="mt-5 text-base font-semibold text-neutral-950">
                  {step.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-neutral-700">
                  {step.description}
                </p>
              </li>
            );
          })
        }
      </ol>
    </div>
  </div>
</section>
