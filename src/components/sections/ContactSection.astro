---
import WhatsAppButton from "../WhatsAppButton.astro";

const contactDetails = [
  "Tipo de prenda o producto textil",
  "Cantidad aproximada",
  "Ubicación del estampado",
  "Tamaño aproximado",
  "Archivo o referencia del diseño",
];

const trustNotes = [
  "Respuesta guiada por los datos del pedido",
  "Archivo revisado antes de confirmar",
  "Coordinación por canales configurables",
];
---

<section
  id="contacto"
  class="border-t border-neutral-200 bg-white"
  aria-labelledby="contacto-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    <div class="rounded-lg border border-neutral-200 bg-neutral-950 p-6 text-white shadow-xl shadow-neutral-950/10 lg:p-8">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-center">
        <div class="space-y-5">
          <div class="space-y-4">
            <p class="text-sm font-semibold uppercase tracking-normal text-neutral-400">
              Contacto
            </p>
            <h2
              id="contacto-title"
              class="text-3xl font-semibold tracking-normal text-white sm:text-4xl"
            >
              Envía tu idea y cotizamos tu estampado.
            </h2>
            <p class="max-w-2xl text-base leading-7 text-neutral-300">
              Cuando los canales estén configurados, podrás iniciar la conversación
              por WhatsApp o Instagram con los datos base del pedido.
            </p>
          </div>

          <ul class="grid gap-2 text-sm text-neutral-300 sm:grid-cols-2">
            {
              contactDetails.map((detail) => (
                <li class="flex gap-2">
                  <span class="text-cyan-300" aria-hidden="true">•</span>
                  <span>{detail}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <WhatsAppButton tone="inverted" />
      </div>

      <ul class="mt-8 grid gap-3 border-t border-white/10 pt-6 sm:grid-cols-3">
        {
          trustNotes.map((note) => (
            <li class="rounded-lg bg-white/[0.08] p-4 text-sm leading-6 text-neutral-300">
              {note}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
