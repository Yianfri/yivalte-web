---
import Card from "../Card.astro";
import SectionHeading from "../SectionHeading.astro";

const formats = [
  {
    title: "Estampado pequeño",
    description:
      "Para logos, nombres o detalles puntuales. Precio pendiente de definición.",
  },
  {
    title: "Estampado mediano",
    description:
      "Para diseños visibles en zonas principales de la prenda. Precio pendiente de definición.",
  },
  {
    title: "Estampado grande",
    description:
      "Para piezas más protagonistas o aplicaciones amplias. Precio pendiente de definición.",
  },
  {
    title: "Cotización personalizada",
    description:
      "Se calcula según tamaño, prenda, cantidad, ubicación y estado del archivo.",
  },
];
---

<section
  id="tamanos-precios"
  class="border-t border-neutral-200 bg-neutral-50"
  aria-labelledby="tamanos-precios-title"
>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-[0.82fr_1fr]">
      <SectionHeading
        eyebrow="Tamaños y precios"
        title="Formatos referenciales para ordenar la cotización."
        titleId="tamanos-precios-title"
        intro="Aún no publicamos precios reales. Esta sección queda lista para completar valores cuando estén definidos."
      />

      <div class="grid gap-4 sm:grid-cols-2">
        {
          formats.map((format) => (
            <Card>
              <h3 class="text-base font-semibold text-neutral-950">
                {format.title}
              </h3>
              <p class="mt-3 text-sm leading-6 text-neutral-700">
                {format.description}
              </p>
            </Card>
          ))
        }
      </div>
    </div>
  </div>
</section>
