---
const navigationItems = [
  { label: "Inicio", href: "/" },
  { label: "Qué hacemos", href: "/que-hacemos/" },
  { label: "Cómo pedir", href: "/como-pedir/" },
  { label: "Tamaños y precios", href: "/tamanos-y-precios/" },
  { label: "Guía de tallas", href: "/guia-de-tallas/" },
  { label: "Contacto", href: "/contacto/" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

const isCurrentPage = (href: string) => {
  const normalizedHref = href.replace(/\/$/, "") || "/";

  return normalizedHref === currentPath;
};
---

<header class="border-b border-neutral-200 bg-white">
  <nav
    class="mx-auto flex max-w-5xl flex-col gap-5 px-6 py-5 lg:flex-row lg:items-center lg:justify-between"
    aria-label="Navegación principal"
  >
    <a class="flex items-center gap-3" href="/" aria-label="Yivalte inicio">
      <!-- Reemplazar este bloque por una imagen cuando esté listo el logo final. -->
      <span
        class="grid h-10 w-10 place-items-center rounded-md bg-neutral-950 text-sm font-semibold text-white"
        aria-hidden="true"
      >
        Y
      </span>
      <span class="text-lg font-semibold tracking-normal text-neutral-950">
        Yivalte
      </span>
    </a>

    <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
      {
        navigationItems.map((item) => (
          <li>
            <a
              class:list={[
                "text-neutral-700 transition-colors hover:text-neutral-950",
                isCurrentPage(item.href) && "font-semibold text-neutral-950",
              ]}
              href={item.href}
              aria-current={isCurrentPage(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
