---
const navigationItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Servicio", href: "#que-hacemos" },
  { label: "Catálogo", href: "#catalogo" },
  { label: "Cómo pedir", href: "#como-pedir" },
  { label: "Archivos", href: "#requisitos-diseno" },
  { label: "Contacto", href: "#contacto" },
];
---

<header class="sticky top-0 z-50 border-b border-neutral-200 bg-white/95 backdrop-blur">
  <nav
    class="mx-auto flex max-w-6xl flex-col gap-5 px-6 py-4 lg:flex-row lg:items-center lg:justify-between"
    aria-label="Navegación principal"
  >
    <a class="flex items-center gap-3" href="#inicio" aria-label="Yivalte inicio">
      <!-- Reemplazar este bloque por una imagen cuando esté listo el logo final. -->
      <span
        class="grid h-10 w-10 place-items-center rounded-md bg-neutral-950 text-sm font-semibold text-white"
        aria-hidden="true"
      >
        Y
      </span>
      <span class="text-lg font-semibold tracking-normal text-neutral-950">
        Yivalte
      </span>
    </a>

    <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm lg:justify-end">
      {
        navigationItems.map((item) => (
          <li>
            <a
              class="rounded-sm text-neutral-700 transition-colors hover:text-neutral-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-neutral-950 focus-visible:ring-offset-4"
              href={item.href}
            >
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
