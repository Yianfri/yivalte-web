---
import { ArrowRight } from "@lucide/astro";

const navigationItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Prendas", href: "#catalogo" },
  { label: "Cómo pedir", href: "#como-pedir" },
  { label: "Tamaños", href: "#guia-tallas" },
  { label: "Contacto", href: "#cotizar" },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-neutral-950/95 text-white backdrop-blur">
  <nav
    class="mx-auto flex max-w-6xl flex-col gap-4 px-6 py-4 lg:flex-row lg:items-center lg:justify-between"
    aria-label="Navegación principal"
  >
    <a class="inline-flex w-fit items-center gap-3" href="#inicio" aria-label="Yivalte inicio">
      <span class="brand-script text-3xl leading-none text-white drop-shadow-[0_0_14px_rgba(255,255,255,0.65)]">
        Yivalte
      </span>
    </a>

    <div class="flex flex-col gap-4 lg:flex-row lg:items-center">
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-xs font-semibold uppercase text-neutral-300">
        {
          navigationItems.map((item) => (
            <li>
              <a
                class="rounded-sm transition-colors hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-neutral-950"
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <a
        class="inline-flex min-h-10 w-fit items-center justify-center rounded-md border border-white/20 px-4 py-2 text-xs font-semibold uppercase text-white transition-colors hover:border-white hover:bg-white hover:text-neutral-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-4 focus-visible:ring-offset-neutral-950"
        href="#cotizar"
      >
        Cotizar
        <ArrowRight class="ml-2 size-4" stroke-width={1.8} aria-hidden="true" />
      </a>
    </div>
  </nav>
</header>
