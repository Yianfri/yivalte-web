---
interface Props {
  eyebrow: string;
  intro: string;
  title: string;
  titleId: string;
  class?: string;
}

const {
  eyebrow,
  intro,
  title,
  titleId,
  class: className = "",
} = Astro.props;
---

<div class={`max-w-2xl space-y-4 ${className}`}>
  <p class="text-sm font-semibold uppercase tracking-normal text-neutral-500">
    {eyebrow}
  </p>
  <h2
    id={titleId}
    class="text-3xl font-semibold tracking-normal text-neutral-950 sm:text-4xl"
  >
    {title}
  </h2>
  <p class="text-base leading-7 text-neutral-700">
    {intro}
  </p>
</div>
